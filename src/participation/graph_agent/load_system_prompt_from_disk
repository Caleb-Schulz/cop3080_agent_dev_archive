def load_system_prompt(path: str = "prompts/yenbase_advisor.md") -> str:
    """Read the advisor's system prompt from a markdown file so that
    business owners can edit loan rates and tone without a code change."""
    prompt_path = Path(path)
    if not prompt_path.exists():
        raise FileNotFoundError(
            f"System prompt not found at {prompt_path.resolve()}. "
            "Create prompts/yenbase_advisor.md (see README)."
        )
    return prompt_path.read_text(encoding="utf-8")

